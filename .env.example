# CBS Sports credentials
CBS_EMAIL=your@email.com
CBS_PASSWORD=yourpassword

# Full URL to your pool's standings page
# Example: https://www.cbssports.com/collegebasketball/brackets/pools/12345678/standings/
CBS_POOL_URL=https://www.cbssports.com/collegebasketball/brackets/pools/YOUR_POOL_ID/standings/

# Your bracket entry name exactly as it appears in the pool standings
MY_BRACKET_NAME=Your Bracket Name Here
